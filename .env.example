# OpenAI (GPT)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# Kimi / Moonshot AI
KIMI_API_KEY=

# Defaults
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# Safety
RUN_TIMEOUT_SECONDS=120
MAX_TOOL_CALLS=5
MAX_CONTEXT_CHARS=12000
ALLOWED_TOPICS=python,golang,mysql,linux,networking,operating-systems,redis,algorithms,system-design

# Storage
DATABASE_URL=sqlite+aiosqlite:///./data/interview_agent.db
EVENT_LOG_DIR=./data/events
KNOWLEDGE_DIR=./knowledge

# Server
HOST=127.0.0.1
PORT=8080
